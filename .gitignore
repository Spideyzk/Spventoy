Thumbs.db
desktop.ini
ehthumbs.db
$RECYCLE.BIN/
.Spotlight-V100
.Trashes

# ── Editors / IDEs ──────────────────────────────────────────────────────────
.vscode/
.idea/
*.code-workspace
*.sublime-*
.history/
