# ── ISO files & cache ────────────────────────────────────────────────────────
*.iso
*.iso.zip
*.img
*.img.gz
*_cache/
isos/
cache/
downloads/

# ── Ventoy artifacts (downloaded by the script at runtime) ──────────────────
ventoy/
ventoy-*/
ventoy-*.zip
ventoy-*.tar.gz
Ventoy2Disk.exe
ventoy.json

# ── Persistence images ──────────────────────────────────────────────────────
persistence.dat
persistence.img
persistence-*.dat

# ── Backup / work-in-progress files ─────────────────────────────────────────
*.bak
*~
*.swp
*.tmp
_*.ps1
_*.sh
_*.cmd
preview-*.png
preview-*.bmp
test-*.bin
test-*.png

# ── Build outputs (Spventoy.exe IS committed; everything else compiled out) ─
*.zip
*.7z
release-*/
dist/
build/
out/

# ── Runtime / temp ──────────────────────────────────────────────────────────
*.iso.partial
*.iso.part*
spventoy_*.json
nul

# ── User-specific custom ISO list ───────────────────────────────────────────
# Leave the example committed; ignore local overrides.
custom-isos.local.json
my-custom-isos.json

# ── Logs ────────────────────────────────────────────────────────────────────
*.log
*.log.*

# ── OS junk ─────────────────────────────────────────────────────────────────
